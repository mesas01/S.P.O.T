PORT=4000
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
ADMIN_SECRET=your_admin_secret_key
CLAIM_PAYER_SECRET=your_claim_payer_secret_key
SPOT_CONTRACT_ID=your_contract_id
MOCK_MODE=false
LOG_FILE=backend/logs/backend.log

# PostgreSQL (used by Prisma)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=${{minio.MINIO_PRIVATE_HOST}}
MINIO_PORT=${{minio.MINIO_PRIVATE_PORT}}
MINIO_ACCESS_KEY=${{minio.MINIO_ROOT_USER}}
MINIO_SECRET_KEY=${{minio.MINIO_ROOT_PASSWORD}}
MINIO_BUCKET=spot-images
# MINIO_PUBLIC_URL=${{minio.MINIO_PUBLIC_ENDPOINT}}

# Optional
# CORS_ORIGIN=*

# Google Gemini
# GEMINI_API_KEY=your_gemini_api_key

# Tier limits
TIER_FREE_MAX_SPOTS_PER_EVENT=100
TIER_FREE_MAX_ACTIVE_EVENTS=3
TIER_FREE_ALLOWED_METHODS=qr,link,code
TIER_BASIC_MAX_SPOTS_PER_EVENT=500
TIER_BASIC_MAX_ACTIVE_EVENTS=10
TIER_BASIC_ALLOWED_METHODS=qr,link,code,geolocation
TIER_PREMIUM_MAX_SPOTS_PER_EVENT=10000
TIER_PREMIUM_MAX_ACTIVE_EVENTS=100
TIER_PREMIUM_ALLOWED_METHODS=qr,link,code,geolocation,nfc

# Integration test settings
# INTEGRATION_CLAIMER_ADDRESS=GD2RRJ7OZPD6DIIZ5BZ6HJ7ALHBVLGQ5QFHJZ2H2SHTK5TNXANGPA2LP
# INTEGRATION_METADATA_URI=https://example.com/metadata.json
# INTEGRATION_IMAGE_URL=https://example.com/image.png
