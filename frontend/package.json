{
  "name": "spot-frontend",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "npm start",
    "start": "concurrently --kill-others-on-fail --names stellar,vite -c gray,green --pad-prefix \"stellar scaffold watch --build-clients\" \"vite\"",
    "build": "tsc -b && vite build",
    "install:contracts": "npm install --workspace=packages && npm run build --workspace=packages",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:integration": "vitest run --config vitest.config.integration.ts"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@stellar/design-system": "^3.1.5",
    "@stellar/stellar-sdk": "^14.6.1",
    "@stellar/stellar-xdr-json": "^23.0.0",
    "@tanstack/react-query": "^5.95.2",
    "@types/qrcode": "^1.5.6",
    "lossless-json": "^4.2.0",
    "lucide-react": "^0.574.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.13.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-dom": "^2.0.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^2.0.3",
    "glob": "^11.0.3",
    "globals": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.1.11",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.1",
    "@google/generative-ai": "^0.21.0"
  }
}
