# Stellar Network Configuration
PUBLIC_STELLAR_NETWORK=TESTNET
PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Backend API base URL
VITE_BACKEND_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}

# SPOT contract ID (must match backend's SPOT_CONTRACT_ID)
VITE_SPOT_CONTRACT_ID=your_contract_id

# WalletConnect project ID (from https://cloud.walletconnect.com, optional)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
